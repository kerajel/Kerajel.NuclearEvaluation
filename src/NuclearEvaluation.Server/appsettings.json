{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "NuclearEvaluationServerDbConnection": ""
  },
  "Sandbox": {
    "SeedOnStartup": true,
    "ResetEnabled": true,
    "ResetIntervalHours": 24,
    "UploadRetentionHours": 24,
    "SweepIntervalMinutes": 30,
    "MaxStorageBytes": 2147483648,
    "MaxUploadsPerIpPerDay": 50,
    "RateLimitWindowSeconds": 60,
    "RateLimitPermitPerWindow": 300
  }
}
